{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/documentation-governor.schema.json",
  "title": "Documentation Governor Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "catalogFile",
    "statusFile",
    "codeGlobs",
    "docGlobs",
    "projectDiscovery"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "baseRef": {
      "type": "string"
    },
    "catalogFile": {
      "type": "string",
      "minLength": 1
    },
    "statusFile": {
      "type": "string",
      "minLength": 1
    },
    "requireDocFileChange": {
      "type": "boolean"
    },
    "codeGlobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "docGlobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ignoreGlobs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "projectDiscovery": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "label",
          "root"
        ],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "root": {
            "type": "string",
            "minLength": 1
          },
          "excludeNames": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
