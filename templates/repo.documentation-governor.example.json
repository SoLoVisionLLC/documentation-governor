{
  "$schema": "./plugins/documentation-governor/schemas/documentation-governor.schema.json",
  "version": 1,
  "baseRef": "origin/main",
  "catalogFile": "docs/maintenance/project-catalog.json",
  "statusFile": "docs/maintenance/documentation-governor-status.json",
  "requireDocFileChange": true,
  "codeGlobs": [
    "apps/**",
    "packages/**",
    "services/**",
    "native/**",
    "scripts/**",
    "package.json",
    ".env.example"
  ],
  "docGlobs": [
    "docs/**",
    "README.md",
    "AGENTS.md",
    ".documentation-governor.json"
  ],
  "ignoreGlobs": [
    "**/node_modules/**",
    "**/.next/**",
    "**/dist/**",
    "**/coverage/**",
    "native/target/**"
  ],
  "projectDiscovery": [
    {
      "label": "apps",
      "root": "apps"
    },
    {
      "label": "packages",
      "root": "packages"
    },
    {
      "label": "services",
      "root": "services"
    },
    {
      "label": "native-crates",
      "root": "native/crates"
    }
  ]
}
